CG02_ACCESS_TOKEN=replace-with-your-token
CG02_SOCKET_HOST=http://localhost:8400
CG02_SOCKET_PATH=/game/cg01/socket.io
CG02_PLATFORM=2
CG02_GAME_ID=cg02
CG02_ACK_TIMEOUT_MS=5000
CG02_WAIT_BETTING_TIMEOUT_MS=12000
CG02_SNAPSHOT_POLL_MS=300

# default bet payload for success/negative scripts
CG02_BET_AMOUNT=0.10
CG02_CURRENCY=CNY
CG02_CASHOUT_TYPE=MANUAL
CG02_AUTO_CASHOUT_AT=0
CG02_PANEL=A

# combined-limit script tuning
CG02_COMBINED_MAX=150
CG02_COMBINED_PANEL_A=A
CG02_COMBINED_AMOUNT_A_CANDIDATES=100,90,80,75,60
CG02_COMBINED_AMOUNT_B_CANDIDATES=100,90,80,75,60,50
